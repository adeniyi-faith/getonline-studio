# Ignore server logs and configuration files
error_log
.DS_Store
Thumbs.db
*.log
php.ini
google-service-account.json

# Ignore standard composer packages
vendor/
test/
testing/

# --- WORDPRESS HOUSING: STRICT EXCLUSION RULES ---
# Block the heavy upload/media folder and plugin asset blocks entirely
wp/wp-content/uploads/
wp/wp-content/plugins/
wp/wp-content/themes/
wp/wp-admin/
wp/wp-includes/

# Ignore native root files inside the /wp directory
wp/wp-*.php
wp/xmlrpc.php
wp/index.php
wp/license.txt
wp/readme.html

# --- WHITELIST CUSTOM FLAGS ---
# Allow your custom mu-plugins files to slide through beautifully
!wp/wp-content/mu-plugins/
