# ======================================================================
# GETONLINE STUDIO - PROGRAMMATIC SEO ROUTING (v5.4 - SAFE + NEIGHBORHOODS)
# ======================================================================
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# --- 0. SITEMAP ARCHITECTURE (MODULAR INDEXING) ---
RewriteRule ^sitemap\.xml$ sitemap-index.php [L]
RewriteRule ^sitemap-core\.xml$ sitemap-core.php [L]
RewriteRule ^sitemap-city-([^/]+)\.xml$ sitemap-city.php?city=$1 [L]

# --- 1. FORCE TRAILING SLASH (SEO BEST PRACTICE) ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^locations/?$ /locations/ [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^locations/([^/]+)/?$ /locations/$1/ [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^locations/([^/]+)/([^/]+)/?$ /locations/$1/$2/ [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^locations/([^/]+)/([^/]+)/([^/]+)$ /locations/$1/$2/$3/ [L,R=301]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^services/([^/]+)/?$ /services/$1/ [L,R=301]

# --- 2. LOCATION & CATEGORY ROUTING ---
# Note: Directory checks (!-d) are removed so the server doesn't crash 
# if empty physical folders happen to exist.

# A. Locations Index
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^locations/?$ locations-index.php [L,QSA]

# B. Listicle Route
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^locations/([a-zA-Z0-9-]+)/top-([a-zA-Z0-9-]+)-web-designers/?$ listicle-landing.php?city=$1&niche=$2 [L,QSA]

# C. HYPER-LOCAL NEIGHBORHOOD ROUTE (3-Tier)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^locations/([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/?$ niche-landing.php?city=$1&neighborhood=$2&niche_service=$3 [L,QSA]

# D. STANDARD CITY NICHE ROUTE (2-Tier)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^locations/([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/?$ niche-landing.php?city=$1&niche_service=$2 [L,QSA]

# E. City Hub Route
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^locations/([a-zA-Z0-9-]+)/?$ city-hub.php?city=$1 [L,QSA]

# --- 3. SERVICES & HUB ROUTING ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^services/?$ services-index.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^services/([a-zA-Z0-9-]+)/?$ niche-hub.php?niche=$1 [L,QSA]

# --- LEGACY /wp/ PREFIX REDIRECT ---
RewriteRule ^wp/locations/(.*)$ /locations/$1 [R=301,L]

</IfModule>
# ======================================================================
# END GETONLINE PSEO ROUTING
# ======================================================================

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress

# BEGIN cPanel-generated php ini directives, do not edit
